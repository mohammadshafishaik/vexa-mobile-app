# VEXA Environment Variables
# Copy this file to .env and fill in the values

# Optional override for backend URL used by mobile app.
# App defaults to production backend unless overridden.
# Example: VEXA_BACKEND_URL=https://api.yourdomain.com
VEXA_BACKEND_URL=

# Optional development flag to force local backend mode.
# When true, app resolves local backend from Metro host (port 3000).
# VEXA_USE_LOCAL_BACKEND=true
VEXA_USE_LOCAL_BACKEND=

# Google OAuth Client ID (will be set in Phase 5)
GOOGLE_WEB_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=

# Razorpay (will be set in Phase 7)
RAZORPAY_KEY_ID=

# Firebase (will be set in Phase 8)
# Configure via google-services.json (Android) and GoogleService-Info.plist (iOS)
