# ═══════════════════════════════════════════════════════════════════════════════
# VEXA 2.0 — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/vexa_db?schema=public"

# ─── JWT Secrets ─────────────────────────────────────────────────────────────
JWT_SECRET="your-jwt-secret-key-here-min-32-chars"
JWT_REFRESH_SECRET="your-refresh-secret-key-here-min-32-chars"

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated allowed web origins (admin panel, web app, etc.)
# Use * only if you intentionally want unrestricted browser access.
CORS_ALLOWED_ORIGINS="http://localhost:3001,http://127.0.0.1:3001"

# ─── Better Auth ─────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET="your-better-auth-secret-here-min-32-chars"
BETTER_AUTH_URL="http://localhost:3000"

# ─── Admin Auth ──────────────────────────────────────────────────────────────
ADMIN_JWT_SECRET="your-admin-jwt-secret"
ADMIN_JWT_REFRESH_SECRET="your-admin-refresh-secret"

# Optional one-time super-admin bootstrap at backend startup.
ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_BOOTSTRAP_EMAIL="superadmin@vexa.app"
ADMIN_BOOTSTRAP_PASSWORD="ChangeThisStrongPassword"
ADMIN_BOOTSTRAP_NAME="VEXA Super Admin"

# ─── Google OAuth 2.0 ────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# ─── Razorpay Payment Gateway ────────────────────────────────────────────────
RAZORPAY_KEY_ID="your_razorpay_key_id"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"
RAZORPAY_WEBHOOK_SECRET="your_razorpay_webhook_secret"

# ─── Escrow ──────────────────────────────────────────────────────────────────
PLATFORM_COMMISSION_RATE=0.10
GST_RATE=0.18
ESCROW_AUTO_RELEASE_HOURS=48

# ─── Email (Resend) ─────────────────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxx"
RESEND_FROM_EMAIL="noreply@vexa.app"
RESEND_FROM_NAME="VEXA"

# ─── Firebase (FCM Push Notifications) ───────────────────────────────────────
FIREBASE_PROJECT_ID="your_firebase_project_id"
FIREBASE_PRIVATE_KEY="your_firebase_private_key"
FIREBASE_CLIENT_EMAIL="your_firebase_client_email"

# ─── Cloudflare Turnstile (Captcha) ─────────────────────────────────────────
CLOUDFLARE_TURNSTILE_SECRET_KEY="0x..."
CLOUDFLARE_TURNSTILE_SITE_KEY="0x..."  # Frontend only, stored for reference

# ─── Cloudinary (Image Uploads) ─────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# ─── Analytics ───────────────────────────────────────────────────────────────
ANALYTICS_FLUSH_INTERVAL_MS=5000
ANALYTICS_BATCH_SIZE=100
