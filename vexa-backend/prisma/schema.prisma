// Prisma Schema for VEXA — Real-time Service Marketplace
// Mirrors frontend types/index.ts exactly

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────

enum UserRole {
  CUSTOMER
  PROVIDER
  ADMIN
}

enum AdminRole {
  SUPER_ADMIN
  MODERATOR
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  BANNED
  DELETED
}

enum KycDocumentType {
  AADHAAR
  PAN
  OTHER
}

enum KycDocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BidAnomalyStatus {
  OPEN
  REVIEWED
  RESOLVED
}

enum BidAnomalyType {
  RAPID_REBID
  EXTREME_UNDERCUT
  COLLUSION_PATTERN
  OTHER
}

enum DisputeDecision {
  REFUND
  PARTIAL_SETTLEMENT
  REJECT
}

enum JobStatus {
  POSTED
  BIDDING
  ACCEPTED
  ON_SITE_INSPECTION
  MODIFICATION_REQUESTED
  IN_PROGRESS
  COMPLETED
  PAYMENT_PENDING
  PAID
  UNDER_DISPUTE
  CANCELLED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  ESCALATED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

enum NotificationType {
  BID_RECEIVED
  BID_ACCEPTED
  JOB_UPDATE
  MODIFICATION_REQUEST
  MODIFICATION_APPROVED
  MODIFICATION_REJECTED
  PAYMENT_RECEIVED
  PAYMENT_COMPLETED
  DISPUTE_OPENED
  DISPUTE_RESOLVED
  RATING_RECEIVED
  SYSTEM
}

// ─── Models ───────────────────────────────────

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  name       String
  password   String?
  googleId   String?  @unique
  avatarUrl  String?
  phone      String?
  role       UserRole @default(CUSTOMER)
  adminRole  AdminRole?
  accountStatus AccountStatus @default(ACTIVE)
  suspendedUntil DateTime?
  banReason  String?
  bannedAt   DateTime?
  bannedById String?
  bannedBy   User?    @relation("UserBanActor", fields: [bannedById], references: [id])
  bannedUsers User[]  @relation("UserBanActor")
  isVerified Boolean  @default(false)
  
  // KYC & Verification
  kycDocuments String[] @default([])
  kycStatus    String   @default("PENDING") // PENDING, VERIFIED, REJECTED
  
  // Push Notifications
  deviceTokens String[] @default([])
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  serviceRequests     ServiceRequest[]     @relation("CustomerJobs")
  selectedForJobs     ServiceRequest[]     @relation("SelectedProvider")
  bids                Bid[]
  modifications       JobModification[]
  paymentsMade        Payment[]            @relation("Payer")
  paymentsReceived    Payment[]            @relation("Payee")
  ratingsGiven        Rating[]             @relation("Rater")
  ratingsReceived     Rating[]             @relation("Ratee")
  disputesRaised      Dispute[]            @relation("DisputeRaiser")
  disputesResolved    Dispute[]            @relation("DisputeResolver")
  notifications       Notification[]
  auditLogs           AuditLog[]
  kycDocumentsUploaded KycDocument[] @relation("UserKycDocuments")
  kycDocumentsReviewed KycDocument[] @relation("KycReviewedBy")
  kycReviewLogs       KycReviewLog[] @relation("KycReviewActor")
  bidAnomaliesFlagged BidAnomaly[] @relation("BidAnomalyProvider")
  bidAnomaliesReviewed BidAnomaly[] @relation("BidAnomalyReviewer")
  disputeResolutions  DisputeResolution[] @relation("DisputeResolvedBy")
  paymentActionLogs   PaymentActionLog[] @relation("PaymentActionActor")
  notificationCampaigns NotificationCampaign[] @relation("NotificationCampaignActor")
  adminSessions       AdminSession[]
  passwordResetTokens PasswordResetToken[]

  emailVerified Boolean   @default(false)
  image         String?
  sessions      Session[]
  accounts      Account[]

  @@map("users")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([token])
  @@map("password_reset_tokens")
}

model ServiceRequest {
  id                 String    @id @default(uuid())
  orderId            String    @unique
  customerId         String
  customer           User      @relation("CustomerJobs", fields: [customerId], references: [id])
  title              String
  description        String
  category           String
  location           String
  latitude           Float?
  longitude          Float?
  scheduledAt        DateTime? // Scheduled date/time for the service
  images             String[]  @default([])
  completedImages    String[]  @default([])
  originalPrice      Float     @default(0)
  urgency            String    @default("NORMAL")
  revisedPrice       Float?
  status             JobStatus @default(POSTED)
  selectedBidId      String?
  selectedProviderId String?
  selectedProvider   User?     @relation("SelectedProvider", fields: [selectedProviderId], references: [id])
  maxModifications   Int       @default(2)
  modificationCount  Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Relations
  bids          Bid[]
  modifications JobModification[]
  payments      Payment[]
  ratings       Rating[]
  disputes      Dispute[]
  bidAnomalies  BidAnomaly[]
  disputeResolutions DisputeResolution[]

  @@map("service_requests")
}

model Bid {
  id                String         @id @default(uuid())
  jobId             String
  job               ServiceRequest @relation(fields: [jobId], references: [id], onDelete: Cascade)
  providerId        String
  provider          User           @relation(fields: [providerId], references: [id])
  amount            Float
  message           String
  estimatedDuration String
  isSelected        Boolean        @default(false)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  anomalies         BidAnomaly[]

  @@unique([jobId, providerId])
  @@map("bids")
}

model JobModification {
  id               String         @id @default(uuid())
  jobId            String
  job              ServiceRequest @relation(fields: [jobId], references: [id], onDelete: Cascade)
  providerId       String
  provider         User           @relation(fields: [providerId], references: [id])
  revisionReason   String
  originalPrice    Float
  revisedPrice     Float
  revisionImages   String[]       @default([])
  approvalStatus   ApprovalStatus @default(PENDING)
  customerResponse String?
  securityHash     String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@map("job_modifications")
}

model Payment {
  id                String         @id @default(uuid())
  jobId             String
  job               ServiceRequest @relation(fields: [jobId], references: [id])
  payerId           String
  payer             User           @relation("Payer", fields: [payerId], references: [id])
  payeeId           String
  payee             User           @relation("Payee", fields: [payeeId], references: [id])
  amount            Float
  currency          String         @default("INR")
  status            PaymentStatus  @default(PENDING)
  paymentMethod     String         @default("RAZORPAY")
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?
  securityHash      String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  actionLogs        PaymentActionLog[]

  @@map("payments")
}

model Rating {
  id        String         @id @default(uuid())
  jobId     String
  job       ServiceRequest @relation(fields: [jobId], references: [id])
  raterId   String
  rater     User           @relation("Rater", fields: [raterId], references: [id])
  rateeId   String
  ratee     User           @relation("Ratee", fields: [rateeId], references: [id])
  score     Int
  review    String
  createdAt DateTime       @default(now())

  @@unique([jobId, raterId])
  @@map("ratings")
}

model Dispute {
  id           String         @id @default(uuid())
  jobId        String
  job          ServiceRequest @relation(fields: [jobId], references: [id])
  raisedById   String
  raisedBy     User           @relation("DisputeRaiser", fields: [raisedById], references: [id])
  reason       String
  evidence     String[]       @default([])
  status       DisputeStatus  @default(OPEN)
  resolution   String?
  resolvedById String?
  resolvedBy   User?          @relation("DisputeResolver", fields: [resolvedById], references: [id])
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  decisions    DisputeResolution[]

  @@map("disputes")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
  @@map("notifications")
}

model AuditLog {
  id            String   @id @default(uuid())
  entityType    String
  entityId      String
  action        String
  performedById String
  performedBy   User     @relation(fields: [performedById], references: [id])
  previousState Json?
  newState      Json?
  ipAddress     String?
  createdAt     DateTime @default(now())

  @@index([entityType, entityId])
  @@map("audit_logs")
}

model KycDocument {
  id           String            @id @default(uuid())
  userId       String
  user         User              @relation("UserKycDocuments", fields: [userId], references: [id], onDelete: Cascade)
  documentType KycDocumentType
  fileKey      String
  fileUrl      String
  status       KycDocumentStatus @default(PENDING)
  remarks      String?
  reviewedById String?
  reviewedBy   User?             @relation("KycReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt   DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  reviewLogs   KycReviewLog[]

  @@index([userId, status])
  @@index([status, createdAt])
  @@map("kyc_documents")
}

model KycReviewLog {
  id            String      @id @default(uuid())
  documentId    String
  document      KycDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  adminId       String
  admin         User        @relation("KycReviewActor", fields: [adminId], references: [id], onDelete: Cascade)
  action        String
  remarks       String?
  previousState Json?
  newState      Json?
  createdAt     DateTime    @default(now())

  @@index([documentId, createdAt])
  @@map("kyc_review_logs")
}

model BidAnomaly {
  id            String           @id @default(uuid())
  bidId         String?
  bid           Bid?             @relation(fields: [bidId], references: [id], onDelete: SetNull)
  jobId         String
  job           ServiceRequest   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  providerId    String?
  provider      User?            @relation("BidAnomalyProvider", fields: [providerId], references: [id], onDelete: SetNull)
  anomalyType   BidAnomalyType
  severityScore Int              @default(0)
  reason        String
  status        BidAnomalyStatus @default(OPEN)
  reviewedById  String?
  reviewedBy    User?            @relation("BidAnomalyReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt    DateTime?
  metadata      Json?
  createdAt     DateTime         @default(now())

  @@index([jobId, status])
  @@index([providerId, status])
  @@map("bid_anomalies")
}

model DisputeResolution {
  id           String          @id @default(uuid())
  disputeId    String
  dispute      Dispute         @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  jobId        String
  job          ServiceRequest  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  decision     DisputeDecision
  refundAmount Float?
  remarks      String?
  resolvedById String
  resolvedBy   User            @relation("DisputeResolvedBy", fields: [resolvedById], references: [id], onDelete: Cascade)
  metadata     Json?
  createdAt    DateTime        @default(now())

  @@index([disputeId, createdAt])
  @@index([jobId, createdAt])
  @@map("dispute_resolutions")
}

model PaymentActionLog {
  id        String   @id @default(uuid())
  paymentId String
  payment   Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  adminId   String
  admin     User     @relation("PaymentActionActor", fields: [adminId], references: [id], onDelete: Cascade)
  action    String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([paymentId, createdAt])
  @@map("payment_action_logs")
}

model AdminSession {
  id               String   @id @default(uuid())
  adminId          String
  admin            User     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  refreshTokenHash String
  ipAddress        String?
  userAgent        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime @default(now())

  @@index([adminId, expiresAt])
  @@index([refreshTokenHash])
  @@map("admin_sessions")
}

model NotificationCampaign {
  id          String   @id @default(uuid())
  title       String
  body        String
  targetType  String
  payload     Json?
  sentById    String
  sentBy      User     @relation("NotificationCampaignActor", fields: [sentById], references: [id], onDelete: Cascade)
  sentAt      DateTime @default(now())
  totalSent   Int      @default(0)
  totalFailed Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([sentById, sentAt])
  @@map("notification_campaigns")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
